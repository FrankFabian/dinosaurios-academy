
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum UserRole {
  ADMIN
  STAFF
  COACH
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum LocationStatus {
  ACTIVE
  INACTIVE
}

enum DisciplineStatus {
  ACTIVE
  INACTIVE
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
}

enum EnrollmentStatus {
  ACTIVE
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum WeekDay {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum StudentCategory {
  PRE_MINI
  MINI
  U13
  U15
  U17
  U19
  OPEN
}


model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  googleSub     String?   @unique
  role          UserRole  @default(STAFF)
  emailVerified DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  coach   Coach?
  staff   Staff?
  student Student?

  markedAttendances        Attendance[]     @relation("AttendanceMarkedBy")
  editedAttendances        Attendance[]     @relation("AttendanceEditedBy")
  requestedStudentLinkOtps StudentLinkOtp[]
  accounts                 Account[]
  sessions                 Session[]

  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model Location {
  id       String         @id @default(cuid())
  name     String
  address  String
  photoUrl String?
  status   LocationStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  disciplines LocationDiscipline[]
  groups      Group[]
  staff       StaffLocation[]

  @@unique([name])
  @@index([status])
}

model Discipline {
  id     String           @id @default(cuid())
  name   String
  icon   String?
  status DisciplineStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations LocationDiscipline[]
  coaches   Coach[]
  groups    Group[]

  @@unique([name])
  @@index([status])
}

model Category {
  id     String         @id @default(cuid())
  name   String
  status CategoryStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups Group[]

  @@unique([name])
  @@index([status])
}

model LocationDiscipline {
  id           String @id @default(cuid())
  locationId   String
  disciplineId String
  maxCapacity  Int

  location   Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  discipline Discipline @relation(fields: [disciplineId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, disciplineId])
}


model Coach {
  id           String  @id @default(cuid())
  userId       String  @unique
  phone        String?
  photoUrl     String?
  disciplineId String?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  discipline Discipline? @relation(fields: [disciplineId], references: [id], onDelete: SetNull)

  groups Group[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Staff {
  id       String  @id @default(cuid())
  userId   String  @unique
  phone    String?
  photoUrl String?

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  locations StaffLocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StaffLocation {
  id         String @id @default(cuid())
  staffId    String
  locationId String

  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([staffId, locationId])
}


model Student {
  id         String   @id @default(cuid())
  userId     String?  @unique

  documentId String   @unique
  firstName  String
  lastName   String

  phone      String?
  email      String   @db.VarChar(320)
  birthDate  DateTime

  category   StudentCategory @default(OPEN)

  photoUrl      String?
  photoPublicId String?

  qrCode     String   @unique
  qrIssuedAt DateTime @default(now())
  linkOtps   StudentLinkOtp[]

  status RecordStatus @default(ACTIVE)

  guardianId String?
  guardian   Guardian? @relation(fields: [guardianId], references: [id], onDelete: SetNull)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  enrollments Enrolment[]
  attendances Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Guardian {
  id         String  @id @default(cuid())
  documentId String? @unique
  firstName  String
  lastName   String
  phone      String?
  email      String? @db.VarChar(320)

  students Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Group {
  id              String    @id @default(cuid())
  locationId      String
  disciplineId    String
  gender          Gender
  categoryId      String
  sessionsPerWeek Int
  daysOfWeek      WeekDay[]
  startMinute     Int
  endMinute       Int
  coachId         String?

  location   Location   @relation(fields: [locationId], references: [id], onDelete: Restrict)
  discipline Discipline @relation(fields: [disciplineId], references: [id], onDelete: Restrict)
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  coach      Coach?     @relation(fields: [coachId], references: [id], onDelete: SetNull)

  enrollments Enrolment[]
  sessions    ClassSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, disciplineId, gender, categoryId, sessionsPerWeek, startMinute, endMinute])
}

model Enrolment {
  id          String           @id @default(cuid())
  studentId   String
  groupId     String
  status      EnrollmentStatus @default(ACTIVE)
  startDate   DateTime
  cancelledAt DateTime?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, groupId, status])
}


model ClassSession {
  id      String   @id @default(cuid())
  groupId String
  date    DateTime

  group      Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attendance Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupId, date])
}

model Attendance {
  id             String           @id @default(cuid())
  sessionId      String
  studentId      String
  status         AttendanceStatus
  markedAt       DateTime         @default(now())
  markedByUserId String?
  editedAt       DateTime?
  editedByUserId String?

  session ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  markedByUser User? @relation("AttendanceMarkedBy", fields: [markedByUserId], references: [id], onDelete: SetNull)
  editedByUser User? @relation("AttendanceEditedBy", fields: [editedByUserId], references: [id], onDelete: SetNull)

  @@unique([sessionId, studentId])
}


model StudentLinkOtp {
  id                String   @id @default(cuid())
  studentId         String
  codeHash          String
  expiresAt         DateTime
  attempts          Int      @default(0)
  requestedByUserId String?

  student         Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  requestedByUser User?   @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}
